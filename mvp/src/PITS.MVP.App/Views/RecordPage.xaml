<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PITS.MVP.App.Views.RecordPage"
             Title="记录行程">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame BorderColor="#E0E0E0" Padding="15">
                <VerticalStackLayout>
                    <Label Text="📍 当前位置" FontAttributes="Bold" FontSize="16"/>
                    <Label Text="{Binding CurrentAddress}" 
                           TextColor="Gray" FontSize="14" Margin="0,5,0,0"/>
                    <Label Text="{Binding CurrentCoords}" 
                           TextColor="LightGray" FontSize="12"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="活动类型" FontAttributes="Bold" FontSize="14"/>
            <CollectionView ItemsSource="{Binding ActivityTypes}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedActivity}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="15,8" CornerRadius="20"
                               BackgroundColor="{Binding Color}">
                            <Label Text="{Binding Icon}" FontSize="16"
                                   TextColor="White" HorizontalOptions="Center"/>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="时间" FontAttributes="Bold" FontSize="14"/>
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                <DatePicker Date="{Binding StartDate}" Grid.Column="0"/>
                <TimePicker Time="{Binding StartTime}" Grid.Column="1"/>
                <Label Text="至" Grid.Column="2" VerticalOptions="Center"/>
            </Grid>
            <Grid ColumnDefinitions="*,Auto">
                <DatePicker Date="{Binding EndDate}" Grid.Column="0"/>
                <TimePicker Time="{Binding EndTime}" Grid.Column="1"/>
            </Grid>

            <Label Text="描述" FontAttributes="Bold" FontSize="14"/>
            <Editor Placeholder="描述这次行程..."
                    Text="{Binding Description}"
                    HeightRequest="80"/>

            <Label Text="可见性级别" FontAttributes="Bold" FontSize="14"/>
            <Picker Title="选择可见性"
                    ItemsSource="{Binding VisibilityLevels}"
                    SelectedItem="{Binding SelectedVisibility}"/>

            <Button Text="保存记录"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="8"
                    Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
