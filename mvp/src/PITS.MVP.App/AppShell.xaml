<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:PITS.MVP.App.Views"
       x:Class="PITS.MVP.App.AppShell"
       Title="PITS">
    
    <TabBar>
        <Tab Title="记录" Icon="record.png">
            <ShellContent ContentTemplate="{DataTemplate views:RecordPage}"/>
        </Tab>
        <Tab Title="日历" Icon="calendar.png">
            <ShellContent ContentTemplate="{DataTemplate views:CalendarPage}"/>
        </Tab>
        <Tab Title="地图" Icon="map.png">
            <ShellContent ContentTemplate="{DataTemplate views:MapPage}"/>
        </Tab>
        <Tab Title="地点" Icon="place.png">
            <ShellContent ContentTemplate="{DataTemplate views:PlacePage}"/>
        </Tab>
        <Tab Title="AI" Icon="ai.png">
            <ShellContent ContentTemplate="{DataTemplate views:AIChatPage}"/>
        </Tab>
        <Tab Title="设置" Icon="settings.png">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}"/>
        </Tab>
    </TabBar>
    
</Shell>
